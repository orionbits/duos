    {
      "id": "lesson_A17",
      "title": "Der Lebenslauf von Peter Meier",
      "blocks": [
        {
          "id": "k1_a17_ex",
          "type": "exercise",
          "content": {
            "instructions": "Was haben Sie über Peter erfahren? Bilden Sie Sätze und berichten Sie.",
            "answers": [
              "Von 2008 bis 2011 hat er Volkswirtschaftslehle (VWL) an der Universität Leipzig studiert.",
              "Sein Schwerpunkt war Finanzökonomie.",
              "Danach hat er von 2011 bis 2013 ein Masterstudium an der Handelshochschule Leipzig absolviert.",
              "Im Sommer 2012 hat Peter ein Praktikum bei der Deutschen Bank in Leipzig gemacht und Arbeitserfahrungen gesammelt.",
              "2013 hat er sein Studium mit dem Master of Science abgeschlossen.",
              "Von 2013 bis 2015 hat er als Mitarbeiter in der Abteilung Strategie und Kontrolle bei Siemens in München gearbeitet.",
              "Seit 2016 ist Peter Marketingmanager bei KODAX in Leipzig.",
              "Er spricht sehr gut Englisch und gut Französisch.",
              "Er beherrscht Microsoft Office."
            ]
          }
        }
      ]
    },
