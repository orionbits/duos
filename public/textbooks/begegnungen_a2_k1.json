        {
          "id": "k1_a1_ex",
          "type": "exercise",
          "content": {
            "instructions": "Fragen Sie Ihre Nachbarin/Ihren Nachbarn und stellen Sie sie/ihn anschließend im Plenum vor.",
            "questions": [
              "Wie heißen Sie?/Wie ist Ihr Name?",
              "Woher kommen Sie?",
              "Wo wohnen Sie?",
              "Welche Sprachen sprechen Sie?",
              "Was sind Sie von Beruf?",
              "Wo arbeiten Sie?",
              "Wo studieren Sie?",
              "Was sind Ihre Hobbys?",
              "Waren Sie schon mal in (Österreich)?",
              "Kennen Sie (Leipzig/einige Leute aus der Gruppe)?",
              "Können Sie (kochen)?"
            ],
            "example_answer": "Meine Nachbarin/Mein Nachbar heißt … Sie/Er kommt aus …"
          }
        }
      ]
    },
    {
      "id": "lesson_A2",
      "title": "Pedro und Martina",
      "blocks": [
        {
          "id": "k1_a2_ex",
          "type": "exercise",
          "content": {
            "instructions": "Hören und lesen Sie. Beantworten Sie die Fragen.",
            "questions": [
              "Wo ist Pedro geboren?",
              "Wo ist Martina zur Schule gegangen?",
              "Was und wo hat Pedro studiert? Wann hat er das Studium abgeschlossen?",
              "Welche Berufsausbildung hat Martina gemacht? Wann hat sie die Ausbildung abgeschlossen?",
              "Welche Ausbildung haben Sie gemacht? Wann haben Sie die Ausbildung/das Studium abgeschlossen?",
              "Wo arbeitet Pedro? Wo arbeitet Martina?",
              "Was muss Pedro bei der Arbeit machen?",
              "Was muss Martina bei der Arbeit machen?",
              "Wo wohnt Pedro? Wo wohnt Martina?",
              "Ist Martina verheiratet? Ist Pedro verheiratet?",
              "Was macht Pedro in seiner Freizeit? Was macht Martina in ihrer Freizeit?"
            ]
          }
        },
        {
